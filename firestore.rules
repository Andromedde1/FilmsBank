rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /movies/{movieId} {
      allow read, write: if true;
    }
    match /history/{entryId} {
      allow read, write: if true;
    }
    match /series/{seriesId} {
      allow read, write: if true;
    }
    match /seriesHistory/{entryId} {
      allow read, write: if true;
    }
  }
}
